# VayuSense Server Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/vayusense?retryWrites=true&w=majority

# JWT secret key (use a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Server port
PORT=5000

# Node environment
NODE_ENV=development

# Groq Cloud API key (for llama-4-scout source attribution)
GROQ_API_KEY=gsk_your_groq_api_key_here

# OpenWeatherMap API key (for air pollution data)
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# Set to true to bypass OWM/MongoDB and use in-memory development databases
USE_MOCK_DB=true
